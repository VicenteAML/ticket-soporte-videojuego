NODE_ENV=development
PORT=3000

# JWT — usar valores largos y aleatorios en producción
JWT_ACCESS_SECRET=cambiar_access_secret_minimo_32_caracteres
JWT_REFRESH_SECRET=cambiar_refresh_secret_minimo_32_caracteres
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# SQLite (ruta relativa al directorio del proyecto)
DB_STORAGE=./database.sqlite
